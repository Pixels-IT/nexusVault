# ╔══════════════════════════════════════════════════════════════════╗
# ║           NexusVault — Configuration (.env)                    ║
# ║  Copiez ce fichier en .env et personnalisez les valeurs         ║
# ║  cp .env.example .env                                           ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── PORT D'ACCÈS ─────────────────────────────────────────────────────────────
# Port sur lequel l'interface web sera accessible.
# Accès : http://votre-serveur:${APP_PORT}
APP_PORT=8080

# ── CHIFFREMENT AES-256 ───────────────────────────────────────────────────────
# Clé utilisée pour chiffrer TOUTES les données sensibles en base SQLite :
# noms d'équipements, adresses IP, identifiants SSH, mots de passe, configs.
#
# ⚠️  OBLIGATOIRE : changez cette valeur AVANT le premier démarrage.
# ⚠️  Ne la modifiez PLUS après le premier démarrage (les données deviendront
#     illisibles car déjà chiffrées avec l'ancienne clé).
#
# Générer une clé sécurisée :
#   openssl rand -hex 32
ENCRYPTION_KEY=CHANGEZ-CETTE-CLE-MAINTENANT-minimum-32-caracteres!!

# ── SECRET JWT ────────────────────────────────────────────────────────────────
# Secret utilisé pour signer les tokens de session.
# ⚠️  Changez cette valeur. Si vous la modifiez, toutes les sessions actives
#     seront invalidées (les utilisateurs devront se reconnecter).
#
# Générer :
#   openssl rand -hex 32
JWT_SECRET=CHANGEZ-CE-SECRET-JWT-AVANT-PRODUCTION!!

# ── FUSEAU HORAIRE ────────────────────────────────────────────────────────────
# Fuseau horaire utilisé pour les horodatages en base de données et les logs.
# Liste complète : https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Paris

# ── NIVEAU DE LOGS ────────────────────────────────────────────────────────────
# debug | info | warn | error  (défaut : info)
LOG_LEVEL=info

# ── NOTE ──────────────────────────────────────────────────────────────────────
# La configuration SMTP (serveur mail) et l'URL de l'application sont
# gérées directement depuis l'interface : Administration → Sécurité → Général.
# Elles sont stockées en base de données et ne nécessitent pas de variables .env.
